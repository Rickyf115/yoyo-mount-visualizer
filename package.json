{
  "name": "yoyo-mount-visualizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "String Trick Engine — model yo-yo string mounts topologically, visualize them in 3D, and discover new tricks via pathfinding over the mount graph.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "hashes": "tsx scripts/print-hashes.ts",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vite": "^8.1.3",
    "vitest": "^3.0.0"
  }
}
